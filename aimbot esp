-- ESP Siêu Nhẹ (Chỉ Box + Health)
local Players, Camera = game:GetService("Players"), workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Tạo 20 object cố định
local boxes, healthBars = {}, {}
for i = 1, 20 do
    boxes[i] = Drawing.new("Quad")
    boxes[i].Visible = false
    healthBars[i] = Drawing.new("Quad")
    healthBars[i].Visible = false
end

game:GetService("RunService").Heartbeat:Connect(function()
    local count = 0
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then continue end
        
        local root = p.Character.HumanoidRootPart
        local head = p.Character:FindFirstChild("Head") or root
        local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end
        
        count = count + 1
        if count > 20 then break end
        
        -- Box
        local headPos = Camera:WorldToViewportPoint(head.Position)
        local height = (Camera:WorldToViewportPoint(root.Position + Vector3.new(0,-3,0)).Y - headPos.Y)
        local width = height * 0.5
        
        local box = boxes[count]
        box.PointA = Vector2.new(headPos.X - width/2, headPos.Y)
        box.PointB = Vector2.new(headPos.X + width/2, headPos.Y)
        box.PointC = Vector2.new(pos.X + width/2, pos.Y)
        box.PointD = Vector2.new(pos.X - width/2, pos.Y)
        box.Color = Color3.fromRGB(255,0,0)
        box.Thickness = 2
        box.Filled = false
        box.Visible = true
        
        -- Health Bar
        local health = p.Character.Humanoid and p.Character.Humanoid.Health / p.Character.Humanoid.MaxHealth or 1
        local hBar = healthBars[count]
        hBar.PointA = Vector2.new(pos.X - width/2, pos.Y + 5)
        hBar.PointB = Vector2.new(pos.X - width/2 + (width * health), pos.Y + 5)
        hBar.PointC = Vector2.new(pos.X - width/2 + (width * health), pos.Y + 8)
        hBar.PointD = Vector2.new(pos.X - width/2, pos.Y + 8)
        hBar.Color = Color3.fromRGB(255*(1-health), 255*health, 0)
        hBar.Filled = true
        hBar.Visible = true
    end
    
    -- Ẩn object thừa
    for i = count + 1, 20 do
        boxes[i].Visible = false
        healthBars[i].Visible = false
    end
end)
