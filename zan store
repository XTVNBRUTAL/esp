    end
    
    if input.KeyCode == Enum.KeyCode.K then
        Config.LegitAimbotEnabled = not Config.LegitAimbotEnabled
        LegitFOVCircle.Visible = Config.LegitAimbotEnabled
        if Config.LegitAimbotEnabled and Config.SilentAimEnabled then
            Config.SilentAimEnabled = false
            FOVCircle.Visible = false
        end
        print("🎯 ZAN STORE Legit Aimbot: " .. (Config.LegitAimbotEnabled and "ON ✅" or "OFF ❌"))
    end
    
    if input.KeyCode == Enum.KeyCode.H then
        Config.ESPEnabled = not Config.ESPEnabled
        if not Config.ESPEnabled then ResetAllObjects() end
        print("👁️ ZAN STORE ESP: " .. (Config.ESPEnabled and "ON ✅" or "OFF ❌"))
    end
end)

-- ===== SPEED =====
local function SpeedBoost()
    if not Config.SpeedEnabled then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    if humanoid.WalkSpeed < 50 then
        humanoid.WalkSpeed = 16 * Config.SpeedMultiplier
        humanoid.JumpPower = 50 * Config.SpeedMultiplier
    end
end

-- ===== RAPID FIRE =====
local RapidFireConnection = nil

local function RapidFire()
    if not Config.RapidFireEnabled then
        if RapidFireConnection then
            RapidFireConnection:Disconnect()
            RapidFireConnection = nil
        end
        return
    end
    
    if not RapidFireConnection then
        RapidFireConnection = RunService.Heartbeat:Connect(function()
            if Config.RapidFireEnabled then
                mouse1click()
                wait(Config.RapidFireDelay)
            end
        end)
    end
end

-- ===== AUTO RELOAD =====
local function AutoReload()
    if not Config.AutoReloadEnabled then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local tool = character:FindFirstChildOfClass("Tool")
    if not tool then return end
    
    local weapon = tool:FindFirstChild("Weapon") or tool:FindFirstChild("Gun") or tool:FindFirstChild("Firearm")
    if not weapon then return end
    
    local ammo = weapon:FindFirstChild("Ammo") or weapon:FindFirstChild("CurrentAmmo") or weapon:FindFirstChild("Bullets")
    if ammo then
        if ammo.Value <= 0 then
            local VirtualInputManager = game:GetService("VirtualInputManager")
            VirtualInputManager:SendKeyEvent(true, "R", false, game)
            wait(0.1)
            VirtualInputManager:SendKeyEvent(false, "R", false, game)
        end
    end
end

