    if Config.GhostEnabled then return true end
    
    local origin = Camera.CFrame.Position
    local direction = (targetPosition - origin).unit * (targetPosition - origin).magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local result = workspace:Raycast(origin, direction, raycastParams)
    return result == nil or result.Instance:IsDescendantOf(targetPosition.Parent)
end

-- ===== LẤY DANH SÁCH MỤC TIÊU =====
local function GetAllTargets()
    local targets = {}
    local playerPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not playerPos then return targets end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        
        local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then continue end
        
        if Config.TeamCheck and player.Team == LocalPlayer.Team then
            continue
        end
        
        if Config.WallCheck and not IsVisible(rootPart) then
            continue
        end
        
        local distance = (rootPart.Position - playerPos.Position).Magnitude
        if distance > Config.ESPDistance then continue end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then continue end
        
        local bones = {}
        local character = player.Character
        if character then
            bones = {
                Head = character:FindFirstChild("Head"),
                Torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"),
                LeftArm = character:FindFirstChild("LeftUpperArm") or character:FindFirstChild("Left Arm"),
                RightArm = character:FindFirstChild("RightUpperArm") or character:FindFirstChild("Right Arm"),
                LeftLeg = character:FindFirstChild("LeftLowerLeg") or character:FindFirstChild("Left Leg"),
                RightLeg = character:FindFirstChild("RightLowerLeg") or character:FindFirstChild("Right Leg"),
                RootPart = rootPart
            }
        end
        
        table.insert(targets, {
            Player = player,
            Character = character,
            RootPart = rootPart,
            Humanoid = humanoid,
            Bones = bones,
            Position = rootPart.Position,
            ScreenPos = Vector2.new(screenPos.X, screenPos.Y),
            Distance = distance,
            IsEnemy = player.Team ~= LocalPlayer.Team,
            Health = humanoid.Health,
            MaxHealth = humanoid.MaxHealth,
            Velocity = humanoid.MoveDirection or Vector3.new(0, 0, 0)
        })
    end
    
    return targets
end

-- ===== LẤY VỊ TRÍ BONE =====
local function GetBoneScreenPos(bone)
    if not bone then return nil end
    local pos, onScreen = Camera:WorldToViewportPoint(bone.Position)
    if onScreen then
        return Vector2.new(pos.X, pos.Y)
    end
    return nil
end

-- ===== VẼ SKELETON =====
local function DrawSkeleton(bones, color, index)
    if not bones then return index end
    
    local function DrawLine(from, to)
        if not from or not to then return index end
        local line = ObjectPool.Skeletons[index]
        if line then
            line.From = from
            line.To = to
            line.Color = color
            line.Thickness = 1.5
            line.Transparency = 0.7
            line.Visible = true
            index = index + 1
        end
        return index
    end
    
    local headPos = GetBoneScreenPos(bones.Head)
    local torsoPos = GetBoneScreenPos(bones.Torso)
    local leftArmPos = GetBoneScreenPos(bones.LeftArm)
    local rightArmPos = GetBoneScreenPos(bones.RightArm)
    local leftLegPos = GetBoneScreenPos(bones.LeftLeg)
    local rightLegPos = GetBoneScreenPos(bones.RightLeg)
    local rootPos = GetBoneScreenPos(bones.RootPart)
    
    if headPos and torsoPos then index = DrawLine(headPos, torsoPos) end
    if torsoPos and leftArmPos then index = DrawLine(torsoPos, leftArmPos) end
    if torsoPos and rightArmPos then index = DrawLine(torsoPos, rightArmPos) end
    if torsoPos and rootPos then index = DrawLine(torsoPos, rootPos) end
    if rootPos and leftLegPos then index = DrawLine(rootPos, leftLegPos) end
    if rootPos and rightLegPos then index = DrawLine(rootPos, rightLegPos) end
    
    local dotIdx = 1
    for _, pos in pairs({headPos, torsoPos, leftArmPos, rightArmPos, leftLegPos, rightLegPos, rootPos}) do
        if pos then
            local dot = ObjectPool.Dots[dotIdx]
            if dot then
                dot.Position = pos
                dot.Radius = 2
                dot.Color = color
                dot.Thickness = 1
                dot.Filled = true
                dot.Visible = true
                dotIdx = dotIdx + 1
            end
        end
    end
    
    return index
end

-- ===== VẼ BOX 3D =====
local function DrawBox3D(rootPart, head, color, index)
    if not rootPart or not head then return index end
    
    local size = rootPart.Size
    local height = size.Y * 1.8
    local width = size.X * 1.5
    local depth = size.Z * 0.8
    
    local center = rootPart.Position
    local points = {}
    
    for x = -1, 1, 2 do
        for y = -1, 1, 2 do
            for z = -1, 1, 2 do
                local p = center + Vector3.new(x * width/2, y * height/2, z * depth/2)
                local screen, onScreen = Camera:WorldToViewportPoint(p)
                if onScreen then
                    table.insert(points, Vector2.new(screen.X, screen.Y))
                end
            end
        end
    end
    
    if #points >= 8 then
        local edges = {
            {1,2}, {2,4}, {4,3}, {3,1},
            {5,6}, {6,8}, {8,7}, {7,5},
            {1,5}, {2,6}, {3,7}, {4,8}
        }
        
        for _, edge in pairs(edges) do
            if points[edge[1]] and points[edge[2]] then
                local line = ObjectPool.Boxes3D[index]
                if line then
                    line.From = points[edge[1]]
                    line.To = points[edge[2]]
                    line.Color = color
                    line.Thickness = 1.5
                    line.Transparency = 0.6
                    line.Visible = true
                    index = index + 1
                end
            end
        end
    end
    
    return index
end

-- ===== VẼ HEALTH BAR =====
local function DrawHealthBar(target, index)
    if not target.Bones.Head or not target.RootPart then return index end
    
    local healthPercent = math.max(0, target.Health / target.MaxHealth)
    local headPos = GetBoneScreenPos(target.Bones.Head)
    local rootPos = GetBoneScreenPos(target.RootPart)
    
    if not headPos or not rootPos then return index end
    
    local height = rootPos.Y - headPos.Y
    local width = height * 0.5
    local barX = headPos.X - width/2
    local barY = rootPos.Y + 5
    local barWidth = width
    local barHeight = 4
    
    local bgBar = ObjectPool.HealthBars[index]
    if bgBar then
        bgBar.PointA = Vector2.new(barX, barY)
        bgBar.PointB = Vector2.new(barX + barWidth, barY)
        bgBar.PointC = Vector2.new(barX + barWidth, barY + barHeight)
        bgBar.PointD = Vector2.new(barX, barY + barHeight)
        bgBar.Color = Color3.fromRGB(30, 30, 30)
        bgBar.Filled = true
        bgBar.Visible = true
        index = index + 1
    end
    
    local healthBar = ObjectPool.HealthBars[index]
    if healthBar then
        healthBar.PointA = Vector2.new(barX, barY)
        healthBar.PointB = Vector2.new(barX + barWidth * healthPercent, barY)
        healthBar.PointC = Vector2.new(barX + barWidth * healthPercent, barY + barHeight)
        healthBar.PointD = Vector2.new(barX, barY + barHeight)
        healthBar.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
        healthBar.Filled = true
        healthBar.Visible = true
        index = index + 1
    end
    
    local healthText = ObjectPool.HealthTexts[index]
    if healthText then
        healthText.Text = string.format("%.0f/%d", target.Health, target.MaxHealth)
        healthText.Color = Color3.fromRGB(255, 255, 255)
        healthText.Size = 9
        healthText.Center = true
        healthText.Outline = true
        healthText.OutlineColor = Color3.fromRGB(0, 0, 0)
        healthText.Position = Vector2.new(barX + barWidth/2, barY + barHeight + 12)
        healthText.Visible = true
        index = index + 1
    end
    
    return index
end

-- ===== VẼ ESP TOP =====
local function DrawESPTop(target, index)
    if not Config.ESPTop then return index end
    if not target.Bones.Head then return index end
    
    local headPos = GetBoneScreenPos(target.Bones.Head)
    if not headPos then return index end
    
    local color = target.IsEnemy and Config.EnemyColor or Config.FriendlyColor
    local healthPercent = target.Health / target.MaxHealth
    
    local topText = string.format("%s | ❤️%.0f%% | 📏%.0fm", 
        target.Player.Name, 
        healthPercent * 100, 
        target.Distance
    )
    
    local bg = ObjectPool.ESPTopBG[index]
    if bg then
        local textWidth = #topText * 6 + 20
        bg.PointA = Vector2.new(headPos.X - textWidth/2, headPos.Y - 40)
        bg.PointB = Vector2.new(headPos.X + textWidth/2, headPos.Y - 40)
        bg.PointC = Vector2.new(headPos.X + textWidth/2, headPos.Y - 20)
        bg.PointD = Vector2.new(headPos.X - textWidth/2, headPos.Y - 20)
        bg.Color = Color3.fromRGB(0, 0, 0)
        bg.Transparency = 0.5
        bg.Filled = true
        bg.Visible = true
        index = index + 1
    end
    
    local text = ObjectPool.ESPTop[index]
    if text then
        text.Text = topText
        text.Color = color
        text.Size = 12
        text.Center = true
        text.Outline = true
        text.OutlineColor = Color3.fromRGB(0, 0, 0)
        text.Position = Vector2.new(headPos.X, headPos.Y - 34)
        text.Visible = true
        index = index + 1
    end
    
    return index
end

-- ===== ĐỊNH VỊ =====
local function DrawTracker(target, index)
    if not target then return index end
    
    local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myPos then return index end
    
    local myScreenPos = Camera:WorldToViewportPoint(myPos.Position)
    local myScreen = Vector2.new(myScreenPos.X, myScreenPos.Y)
    
    local tracker = ObjectPool.Trackers[index]
    if tracker then
        tracker.From = myScreen
        tracker.To = target.ScreenPos
        tracker.Color = Config.TrackerColor
        tracker.Thickness = 1.5
        tracker.Transparency = 0.4
        tracker.Visible = true
        index = index + 1
    end
    
    local dot = ObjectPool.TrackerDots[index]
    if dot then
        dot.Position = target.ScreenPos
        dot.Radius = 6
        dot.Color = Config.TrackerColor
        dot.Thickness = 2
        dot.Filled = true
        dot.Transparency = 0.7
        dot.Visible = true
        index = index + 1
    end
    
    local ring = ObjectPool.TrackerDots[index]
    if ring then
        local pulse = math.sin(tick() * 3) * 2 + 8
        ring.Position = target.ScreenPos
        ring.Radius = pulse
        ring.Color = Config.TrackerColor
        ring.Thickness = 1.5
        ring.Filled = false
        ring.Transparency = 0.5 + math.sin(tick() * 3) * 0.2
        ring.Visible = true
        index = index + 1
    end
    
    if target.Velocity and target.Velocity.Magnitude > 0.5 then
        local dirPos = target.RootPart.Position + (target.Velocity.Unit * 5)
        local dirScreen, onScreen = Camera:WorldToViewportPoint(dirPos)
        if onScreen then
            local arrow = ObjectPool.TrackerArrows[index]
            if arrow then
                arrow.From = target.ScreenPos
                arrow.To = Vector2.new(dirScreen.X, dirScreen.Y)
                arrow.Color = Color3.fromRGB(255, 255, 0)
                arrow.Thickness = 2
                arrow.Transparency = 0.6
                arrow.Visible = true
                index = index + 1
            end
        end
    end
    
    return index
end

-- ===== UPDATE ESP =====
local function UpdateESP()
    if not Config.ESPEnabled then
        ResetAllObjects()
        return
    end
    
    ResetAllObjects()
    
    local targets = GetAllTargets()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    local boxIdx = 1
    local skelIdx = 1
    local healthIdx = 1
    local nameIdx = 1
    local distIdx = 1
    local tracerIdx = 1
    local trackerIdx = 1
    local topIdx = 1
    
    for _, target in pairs(targets) do
        local color = target.IsEnemy and Config.EnemyColor or Config.FriendlyColor
        
        if Config.Box3D then
            boxIdx = DrawBox3D(target.RootPart, target.Bones.Head, color, boxIdx)
        end
        
        if Config.Skeleton then
            skelIdx = DrawSkeleton(target.Bones, Config.SkeletonColor, skelIdx)
        end
        
        if Config.HealthBar then
            healthIdx = DrawHealthBar(target, healthIdx)
        end
        
        if Config.ESPTop then
            topIdx = DrawESPTop(target, topIdx)
        end
        
        if Config.NameESP and not Config.ESPTop then
            local headPos = GetBoneScreenPos(target.Bones.Head)
            if headPos then
                local nameObj = ObjectPool.Names[nameIdx]
                if nameObj then
                    nameObj.Text = target.Player.Name
                    nameObj.Color = color
                    nameObj.Size = 13
                    nameObj.Center = true
                    nameObj.Outline = true
                    nameObj.OutlineColor = Color3.fromRGB(0, 0, 0)
                    nameObj.Position = Vector2.new(target.ScreenPos.X, headPos.Y - 25)
                    nameObj.Visible = true
                    nameIdx = nameIdx + 1
                end
            end
        end
        
        if Config.DistanceESP and not Config.ESPTop then
            local distObj = ObjectPool.Distances[distIdx]
            if distObj then
                distObj.Text = string.format("📏 %.0fm", target.Distance)
                distObj.Color = Color3.fromRGB(200, 200, 200)
                distObj.Size = 11
                distObj.Center = true
                distObj.Outline = true
                distObj.OutlineColor = Color3.fromRGB(0, 0, 0)
                distObj.Position = Vector2.new(target.ScreenPos.X, target.ScreenPos.Y + 40)
                distObj.Visible = true
                distIdx = distIdx + 1
            end
        end
        
        if Config.LineTracer then
            local tracer = ObjectPool.Tracers[tracerIdx]
            if tracer then
                tracer.From = screenCenter
                tracer.To = target.ScreenPos
                tracer.Color = Config.TracerColor
                tracer.Thickness = 1.5
                tracer.Transparency = 0.5
                tracer.Visible = true
                tracerIdx = tracerIdx + 1
            end
        end
        
        if Config.Tracker then
            trackerIdx = DrawTracker(target, trackerIdx)
        end
    end
end

-- ===== SILENT AIM =====
local function SilentAim()
    if not Config.SilentAimEnabled then return end
    
    if not UserInputService:IsKeyDown(Config.SilentAimKey) then return end
    
    local targets = GetAllTargets()
    if #targets == 0 then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    local closestTarget = nil
    local shortestDist = math.huge
    
    for _, target in pairs(targets) do
        local targetPart = target.Character:FindFirstChild(Config.AimPart) or target.Bones.Head or target.RootPart
        if targetPart then
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if dist < shortestDist and dist < Config.SilentAimFOV then
                    shortestDist = dist
                    closestTarget = target
                end
            end
        end
    end
    
    if closestTarget then
        local targetPart = closestTarget.Character:FindFirstChild(Config.AimPart) or closestTarget.Bones.Head or closestTarget.RootPart
        if targetPart then
            local targetPos = Camera:WorldToViewportPoint(targetPart.Position)
            local delta = Vector2.new(targetPos.X, targetPos.Y) - mousePos
            
            mousemoverel(delta.X * Config.Smoothness, delta.Y * Config.Smoothness)
            
            if Config.AutoShoot then
                if delta.Magnitude < Config.SilentAimFOV then
                    mouse1click()
                    wait(Config.AutoShootDelay)
                end
            end
        end
    end
end

-- ===== LEGIT AIMBOT =====
local function LegitAimbot()
    if not Config.LegitAimbotEnabled then return end
    
    local targets = GetAllTargets()
    if #targets == 0 then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    local closestTarget = nil
    local shortestDist = math.huge
    
    for _, target in pairs(targets) do
        local targetPart = target.Character:FindFirstChild(Config.AimPart) or target.Bones.Head or target.RootPart
        if targetPart then
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if dist < shortestDist and dist < Config.LegitAimbotFOV then
                    shortestDist = dist
                    closestTarget = target
                end
            end
        end
    end
    
    if closestTarget then
        local targetPart = closestTarget.Character:FindFirstChild(Config.AimPart) or closestTarget.Bones.Head or closestTarget.RootPart
        if targetPart then
            local targetPos = Camera:WorldToViewportPoint(targetPart.Position)
            local delta = Vector2.new(targetPos.X, targetPos.Y) - mousePos
            
            local angle = math.sqrt(delta.X^2 + delta.Y^2)
            if angle > Config.LegitMaxAngle then
                delta = delta / angle * Config.LegitMaxAngle
            end
            
            if Config.LegitHumanize then
                local randomOffset = Vector2.new(
                    (math.random() - 0.5) * 0.5,
                    (math.random() - 0.5) * 0.5
                )
                delta = delta + randomOffset
            end
            
            mousemoverel(delta.X * Config.LegitSmoothness, delta.Y * Config.LegitSmoothness)
            
            if Config.LegitAutoShoot then
                if angle < Config.LegitAimbotFOV then
                    mouse1click()
                    wait(0.05)
                end
            end
        end
    end
end

